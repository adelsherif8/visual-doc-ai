# Copy to .env and fill in. With NO keys set, the app runs in deterministic
# MOCK mode over the bundled sample documents (no network, no cost) so the
# demo always works.

# --- OpenAI (required for live VLM extraction on uploaded documents) ---
OPENAI_API_KEY=sk-...

# --- Langfuse (optional: live traces + token/cost of every extraction) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com   # or https://us.cloud.langfuse.com

# --- Vision-language model used for extraction ---
VLM_MODEL=gpt-4o-mini
